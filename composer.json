{
    "name": "fanmade/laravel-delegated-permissions",
    "description": "Inheritance-based, scoped authorization for Laravel: each role delegates a subset of its own permissions to its children, and revoking cascades down the tree.",
    "keywords": ["laravel", "authorization", "permissions", "roles", "rbac", "delegation"],
    "homepage": "https://github.com/Fanmade/laravel-delegated-permissions",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/container": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Fanmade\\DelegatedPermissions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fanmade\\DelegatedPermissions\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fanmade\\DelegatedPermissions\\DelegatedPermissionsServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
